{
  "name": "curriculum_short_then_full",
  "base": {
    "game": {
      "size": 4,
      "n_landmarks": 1,
      "n_clues": 1,
      "n_questions": 0,
      "max_moves": 64,
      "history_len": 16,
      "instant_reward_multiplier": 2.0,
      "end_reward_multiplier": 10.0
    },
    "training": {
      "batch_size": 32,
      "n_epochs": 5,
      "n_episodes": 300,
      "training_epochs": 2,
      "gamma": 0.99,
      "alpha": 0.0002,
      "gae_lambda": 0.95,
      "policy_clip": 0.1
    },
    "agents": {
      "sender": {
        "kind": "ppo",
        "hidden_size": 512
      },
      "receiver": {
        "kind": "ppo",
        "hidden_size": 512
      }
    }
  },
  "curriculum": [
    {
      "name": "stage_01_fast_bootstrap",
      "game": {
        "n_landmarks": 1
      },
      "training": {
        "n_episodes": 200,
        "training_epochs": 2
      },
      "warm_start_from_previous_stage": false
    },
    {
      "name": "stage_02_full_baseline",
      "game": {
        "n_landmarks": 1
      },
      "training": {
        "n_episodes": 1000,
        "training_epochs": 5
      },
      "warm_start_from_previous_stage": true
    }
  ]
}